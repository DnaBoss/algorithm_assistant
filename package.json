{
  "name": "exactlyone",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "cargo run --manifest-path server/Cargo.toml -- serve",
    "db:migrate": "cargo run --manifest-path server/Cargo.toml -- migrate",
    "db:seed-admin": "cargo run --manifest-path server/Cargo.toml -- seed-admin",
    "build": "tsc -b && vite build",
    "build:api": "cargo check --manifest-path server/Cargo.toml",
    "check:platform-exports": "node scripts/import-platform-exports.mjs && node scripts/easy-pg-schema-to-platform-export.mjs --self-test",
    "import:easy-pg-schema": "node scripts/easy-pg-schema-to-platform-export.mjs --input .platform-local/easy-pg-schema.local.json --output src/platformExports.generated.json --tables-file .platform-local/easy-pg-public-tables.local.txt",
    "check:tracks": "node scripts/check-track-pages.mjs",
    "release:gate": "bash scripts/release-gate.sh",
    "test": "npm run test:frontend && npm run test:api",
    "test:frontend": "vitest run",
    "test:api": "cargo test --manifest-path server/Cargo.toml",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
